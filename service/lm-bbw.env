# Sets Logging level (INFO, DEBUG, WARN, ERROR)
LOGLEVEL=INFO

# Sets display rendering in 'portrait' or 'landscape'
DISPLAY_ORIENTATION=landscape

# Main Loop Speed (Heartbeat) - Keep fast (0.1) for responsive buttons
REFRESH_RATE=0.3

# Graph History - Keep 60 seconds of data on screen
GRAPH_HISTORY_SECONDS=60

# Drip-out window: time (seconds) to continue tracking the weight after brewing stops
DRIP_OUT_WINDOW=3.5

# Graph limits
GRAPH_MAX_VALUE=3
GRAPH_MAX_DENSITY_THRESHOLD=5

# Graph Smoothing - Lower is more responsive.
# Controls how many data points are averaged for the line drawing (higher = smoother but more lag)
# If commented out, it defaults to calculating based on refresh rate (approx 10)
FLOW_SMOOTHING_FACTOR=30

# Revert the screen to the Ready/logo view after this many seconds of
# inactivity following a shot (button press or weight change resets it).
# Softer than sleep: the scale stays connected and the screen stays on.
# Keep this <= IDLE_TIMEOUT so it shows before the system fully sleeps.
READY_SCREEN_TIMEOUT=60

# 1. How long to wait before sleeping (Seconds). For example: 600 = 10 mins.
IDLE_TIMEOUT=300

# 2. How long to STOP scanning (Seconds) once sleep starts.
# After this time, scanning restarts automatically.
# Set to time which gives the scale plenty of time to turn off.
SLEEP_PAUSE=360

# Activity Threshold:
# Weight (g) change required to reset the idle timer (wake from sleep).
# Must be enough to overcome scale noise (typically 0.1-0.2g).
ACTIVITY_WEIGHT_THRESHOLD=0.3

# Screen Brightness (0 to 100)
DISPLAY_BRIGHTNESS=100

# Memory Profile Colors (Hex Codes)
# Default colors are Red #ff1303, Green #25a602, Blue #376efa
MEMORY_A_COLOR=#ff0000
MEMORY_B_COLOR=#00ff70
MEMORY_C_COLOR=#0070ff


# Memory Profile Names (optional, human-readable)
# If set, the header shows this name (e.g. "Espresso") instead of "TARGET A".
# Leave blank or commented out to keep the default TARGET A / B / C labels.
# Keep names short (~8 chars) so they fit; longer names auto-shrink font size.
MEMORY_A_NAME=Espresso
MEMORY_B_NAME=Lungo
MEMORY_C_NAME=Ristretto
